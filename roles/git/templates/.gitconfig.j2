[color]
  diff = auto
  status = auto
  branch = auto
[color "blame"]
  highlightRecent = {{ git['config']['blame']['color']['highlight_recent'] }}
[core]
  autocrlf = input
  editor = {{ git['config']['core']['editor'] }}
  excludesfile = {{ git['config']['core']['excludesfile'] }}
  pager = {{ git['config']['core']['pager'] }}
{% if ansible_os_family == 'Darwin' %}
[credential]
  helper = osxkeychain
{% endif %}
[user]
  name = {{ git['config']['user']['name'] }}
[blame]
  coloring = {{ git['config']['blame']['coloring'] }}
[init]
    defaultBranch = {{ git['config']['init']['default_branch'] }}
[fetch]
  prune = {{ git['config']['fetch']['prune'] }}
  tags = {{ git['config']['fetch']['tags'] }}
{% for organisation in git['organisation_emails'] | dict2items %}
[includeIf "gitdir:{{ git['organisation_email_base'] }}/{{ organisation.key }}/"]
  path = ~/.gitconfig.d/{{ organisation.key }}.gitconfig
{% endfor %}
